#!/bin/bash

server_name=$(git rev-parse --show-toplevel 2>/dev/null | sed -e "s/[\.\/]/_/g")
server_name=${server_name:=main}
socket_file=$(kak -l | grep $server_name)

if [[ $socket_file == "" ]]; then        
    # Create new kakoune daemon for project
    setsid kak -d -s $server_name &
    sleep 0.1
fi

# and run kakoune (with any arguments passed to the script)
kak -c $server_name $@
